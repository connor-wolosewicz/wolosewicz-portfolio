ggplot(aes(x=ACRES)) +
geom_histogram(binwidth = 5, fill = "darkgreen", color =    "white") + labs(title = "Distribution of NYC Park Sizes",
x = "Park Size (Acres)", y = "Number of Parks", caption = "Source: NYC Open Data — Parks Properties")
