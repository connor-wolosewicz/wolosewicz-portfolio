parks_clean |>
ggplot(aes(x = BOROUGH)) +
geom_bar(fill = "darkgreen", color = "white") +
labs(title = "Number of Park Properties by Borough",
x = "Borough",
y = "Number of Parks",
caption = "Source: NYC Open Data - Parks Properties"
)
parks_clean |>
ggplot(aes(x = TYPECATEGORY)) +
geom_bar(fill = "darkgreen", color = "white") +
coord_flip() +
labs(title = "Number of Park Properties by Type",
x = "Park Type",
y = "Number of Parks",
caption = "Source: NYC Open Data - Parks Properties"
)
parks_clean |>
count(TYPECATEGORY) |>
arrange(desc(n))
parks_clean <- parks |>
select(ACRES, BOROUGH, TYPECATEGORY, WATERFRONT) |>
mutate(
BOROUGH = recode(BOROUGH,
"B" = "Bronx",
"M" = "Manhattan",
"Q" = "Queens",
"R" = "Staten Island",
"X" = "Brooklyn"),
BOROUGH = as.factor(BOROUGH),
TYPECATEGORY = as.factor(TYPECATEGORY)
) |>
filter(!is.na(ACRES)) |>
group_by(TYPECATEGORY) |>
filter(n() >=10) |>
ungroup()
parks_clean |>
ggplot(aes(x = BOROUGH)) +
geom_bar(fill = "darkgreen", color = "white") +
labs(title = "Number of Park Properties by Borough",
x = "Borough",
y = "Number of Parks",
caption = "Source: NYC Open Data - Parks Properties"
)
parks_clean |>
ggplot(aes(x = TYPECATEGORY)) +
geom_bar(fill = "darkgreen", color = "white") +
coord_flip() +
labs(title = "Number of Park Properties by Type",
x = "Park Type",
y = "Number of Parks",
caption = "Source: NYC Open Data - Parks Properties"
)
parks_clean |>
ggplot(aes(x = TYPECATEGORY)) +
geom_bar(fill = "darkgreen", color = "white") +
coord_flip() +
labs(title = "Number of Park Properties by Type",
x = "Park Type",
y = "Number of Parks",
caption = "Source: NYC Open Data - Parks Properties"
) + theme_minimal()
parks_clean |>
ggplot(aes(x = BOROUGH)) +
geom_bar(fill = "darkgreen", color = "white") +
labs(title = "Number of Park Properties by Borough",
x = "Borough",
y = "Number of Parks",
caption = "Source: NYC Open Data - Parks Properties"
) + theme_minimal()
parks_clean |>
ggplot(aes(x = TYPECATEGORY)) +
geom_bar(fill = "darkgreen", color = "white") +
coord_flip() +
labs(title = "Number of Park Properties by Type",
x = "Park Type",
y = "Number of Parks",
caption = "Source: NYC Open Data - Parks Properties"
) + theme_minimal()
parks_clean |>
ggplot(aes(x = BOROUGH, y = ACRES)) +
geom_boxplot(fill = "darkgreen", color = "black") +
ylim(0, 15) +
labs(
title = "Park Size by Borough",
x = "Borough",
y = "Park Size (Acres)",
caption = "Source: NYC Open Data - Parks Properties"
) +
theme_minimal()
parks_clean <- parks |>
select(ACRES, BOROUGH, TYPECATEGORY, WATERFRONT) |>
mutate(
BOROUGH = recode(BOROUGH,
"B" = "Brooklyn",
"M" = "Manhattan",
"Q" = "Queens",
"R" = "Staten Island",
"X" = "Bronx"),
BOROUGH = as.factor(BOROUGH),
TYPECATEGORY = as.factor(TYPECATEGORY)
) |>
filter(!is.na(ACRES)) |>
group_by(TYPECATEGORY) |>
filter(n() >=10) |>
ungroup()
