---
title: "NYC 2015 Street Tree Data"
```{r}
library(tidyverse)
trees <- read_csv("2015_Street_Tree_Census_-_Tree_Data_20260423.csv")
glimpse(trees)
unique(trees$health)
unique(trees$status)
unique(trees$borough)
glimpse(trees_two)
trees_clean <- trees |>
select(tree_dbh, health, borough, steward, status, spc_common) |>
filter(status == "Alive") |>
filter(health %in% c("Good", "Fair", "Poor")) |>
filter(!is.na(tree_dbh), !is.na(health), !is.na(borough)) |>
filter(tree_dbh > 0) |>
mutate(
health = factor(health, levels = c("Poor", "Fair", "Good")),
borough = as.factor(borough)
)
trees_two <- trees_clean |>
filter(borough %in% c("Manhattan", "Bronx")) |>
mutate(borough = droplevels(borough))
glimpse(trees_two)
trees_two |>
group_by(borough, health) |>
summarize(n = n(), .groups = "drop") |>
group_by(borough) |>
mutate(proportion = round(n / sum(n), 3))
trees_two |>
group_by(borough, health) |>
summarize(n = n(), .groups = "drop") |>
group_by(borough) |>
mutate(proportion = n / sum(n)) |>
ggplot(aes(x = borough, y = proportion, fill = health)) +
geom_bar(stat = "identity", position = "dodge") +
scale_fill_manual(values = c("Poor" = "#d73027", "Fair" = "#fee08b", "Good" = "#1a9850")) +
labs(
title = "Street Tree Health by Borough",
x = "Borough",
y = "Proportion of Trees",
fill = "Health",
caption = "Source: NYC Open Data - 2015 Street Tree Census"
) +
theme_minimal()
set.seed(2025)
bronx_boot <- trees_two |>
filter(borough == "Bronx") |>
mutate(is_good = ifelse(health == "Good", 1, 0)) |>
specify(response = is_good) |>
generate(reps = 1000, type = "bootstrap") |>
calculate(stat = "mean")
set.seed(2025)
bronx_data <- trees_two |>
filter(borough == "Bronx") |>
mutate(is_good = ifelse(health == "Good", 1, 0))
bronx_boot <- tibble(
stat = replicate(1000, mean(sample(bronx_data$is_good,
size = nrow(bronx_data),
replace = TRUE)))
)
bronx_ci <- CI_boot(bronx_boot, level = 0.95)
#| include: false
CI_boot <- function(boot_dist, level = 0.95) {
alpha <- 1 - level
tibble(
lower_ci = quantile(boot_dist$stat, alpha / 2),
upper_ci = quantile(boot_dist$stat, 1 - alpha / 2)
)
}
set.seed(2025)
bronx_data <- trees_two |>
filter(borough == "Bronx") |>
mutate(is_good = ifelse(health == "Good", 1, 0))
bronx_boot <- tibble(
stat = replicate(1000, mean(sample(bronx_data$is_good,
size = nrow(bronx_data),
replace = TRUE)))
)
bronx_ci <- CI_boot(bronx_boot, level = 0.95)
manhattan_data <- trees_two |>
filter(borough == "Manhattan") |>
mutate(is_good = ifelse(health == "Good", 1, 0))
manhattan_boot <- tibble(
stat = replicate(1000, mean(sample(manhattan_data$is_good,
size = nrow(manhattan_data),
replace = TRUE)))
)
manhattan_ci <- CI_boot(manhattan_boot, level = 0.95)
obs_props <- trees_two |>
group_by(borough) |>
summarize(observed = mean(health == "Good"))
ci_summary <- tibble(
group = c("Bronx", "Manhattan"),
observed = obs_props$observed,
lower = c(bronx_ci$lower_ci, manhattan_ci$lower_ci),
upper = c(bronx_ci$upper_ci, manhattan_ci$upper_ci)
)
ci_summary |>
ggplot(aes(x = group, y = observed)) +
geom_col(fill = "darkgreen", color = "white", width = 0.5) +
geom_errorbar(aes(ymin = lower, ymax = upper), width = 0.15, linewidth = 0.8) +
labs(
title = "Proportion of Trees in Good Health by Borough",
x = "Borough",
y = "Proportion in Good Health",
caption = "Source: NYC Open Data - 2015 Street Tree Census"
) +
theme_minimal()
